        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph LR\n    title \&quot;Machine Controller Reconcile Flow\&quot;\n    style title fill:#f9f,stroke:#333,stroke-width:2px,color:#fff\n    style node fill:#f9f,stroke:#333,stroke-width:2px\n    style decision fill:#f9f,stroke:#333,stroke-width:2px\n    style error fill:#fdd,stroke:#a00,stroke-width:2px\n    style start fill:#f9f,stroke:#333,stroke-width:2px\n    style end fill:#f9f,stroke:#333,stroke-width:2px\n\n    start[Watch Machine resource events]\n    start --&gt;|Yes| reconcile_request_received[Reconcile request received]\n    reconcile_request_received --&gt;|Yes| fetch_machine_resource[Fetch Machine resource from Kubernetes API]\n    fetch_machine_resource --&gt;|Yes| decision_machine_found[Machine resource found in Kubernetes?]\n    decision_machine_found --|No|-&gt; nothing_to_reconcile[End: Nothing to reconcile]\n    decision_machine_found --|Yes|-&gt; ensure_finalizer_present[Ensure finalizer is present]\n\n    ensure_finalizer_present --&gt;|Yes| decision_deletion_timestamp_set[Deletion timestamp set?]\n    decision_deletion_timestamp_set --|Yes|-&gt; deletion_flow[Deletion flow]\n    deletion_flow --&gt;|Yes| query_vcenter_vm[Query vCenter for corresponding VM]\n    query_vcenter_vm --&gt;|Yes| decision_vm_exists[VM exists in vCenter?]\n    decision_vm_exists --|Yes|-&gt; delete_vm[Delete VM in vCenter]\n    delete_vm --&gt;|Yes| remove_finalizer[Remove finalizer]\n    remove_finalizer --&gt;|Yes| update_machine_status[Update Machine status / conditions]\n    update_machine_status --&gt;|Yes| end_finish_reconcile[End: Finish reconcile]\n    delete_vm --|No|-&gt; skip_delete_vm_not_found[Skip delete, VM not found]\n    skip_delete_vm_not_found --&gt;|Yes| end_finish_reconcile\n\n    ensure_finalizer_present --|No|-&gt; normal_create_update_flow[Normal create/update flow]\n    normal_create_update_flow --&gt;|Yes| validate_machine_spec[Validate Machine spec]\n    validate_machine_spec --&gt;|Yes| query_vcenter_vm_by_machine_identity[Query vCenter for VM by Machine identity]\n    query_vcenter_vm_by_machine_identity --&gt;|Yes| decision_vm_exists\n    decision_vm_exists --|Yes|-&gt; create_vm[Create VM in vCenter from Machine spec]\n    create_vm --&gt;|Yes| update_machine_status\n    create_vm --|No|-&gt; compare_desired_machine_spec_with_actual_vm_state[Compare desired Machine spec with actual VM state]\n    compare_desired_machine_spec_with_actual_vm_state --&gt;|Yes| decision_drift_detected[Drift detected?]\n    decision_drift_detected --|Yes|-&gt; reconfigure_update_vm[Reconfigure / update VM in vCenter]\n    reconfigure_update_vm --&gt;|Yes| update_machine_status\n    reconfigure_update_vm --|No|-&gt; no_changes_needed_vm_already_matches_desired_state[No changes needed, VM already matches desired state]\n    no_changes_needed_vm_already_matches_desired_state --&gt;|Yes| update_machine_status\n    no_changes_needed_vm_already_matches_desired_state --|No|-&gt; end_finish_reconcile\n\n    error[Set Ready=False / Error condition and requeue]\n    query_vcenter_vm --&gt;|Yes|-&gt; error\n    delete_vm --&gt;|Yes|-&gt; error\n    create_vm --&gt;|Yes|-&gt; error\n    reconfigure_update_vm --&gt;|Yes|-&gt; error\n    error --&gt;|Yes|-&gt; reconcile_request_received\n\n    style decision_machine_found fill:#0a0,stroke:#0a0,stroke-width:2px\n    style decision_vm_exists fill:#0a0,stroke:#0a0,stroke-width:2px\n    style decision_drift_detected fill:#0a0,stroke:#0a0,stroke-width:2px&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="56">
